; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="FriendslopEZPZ"
run/main_scene="uid://yv267dbktknq"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

SteamInfo="*uid://bnrrf8q027js4"
Network="*uid://cq3b8bnp6no5g"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/easy_peasy_multiplayer/plugin.cfg", "res://addons/godotsteam/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://docs/": "purple"
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"

[steam]

initialization/app_data/app_type=0
initialization/app_data/app_id=0
initialization/app_data/demo_id=0
initialization/app_data/playtest_id=0
initialization/app_data/tool_id=0
initialization/processes/initialize_on_startup=false
initialization/processes/embed_callbacks=false
multiplayer_peer/max_channels=4

[steam_server]

initialization/embed_callbacks=false

[text_editor]

text_editor/external/use_external_editor=true
text_editor/external/exec_path="flatpak"
text_editor/external/exec_flags="run dev.zed.Zed {project} {file}:{line}:{col}"
